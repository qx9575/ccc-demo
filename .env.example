# Agent v0.2 配置文件
# 复制为 .env 并填入实际值

# ============================================
# LLM API 配置（支持多种模型）
# ============================================

# === GLM/智谱 AI (默认) ===
OPENAI_API_KEY=your_glm_key_here
OPENAI_BASE_URL=https://maas-api.ai-yuanjing.com/openapi/compatible-mode/v1
OPENAI_MODEL=glm-4-flash

# === OpenAI GPT ===
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# === DeepSeek ===
# OPENAI_API_KEY=sk-your-deepseek-key
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# === Kimi/月之暗面 ===
# OPENAI_API_KEY=sk-your-moonshot-key
# OPENAI_BASE_URL=https://api.moonshot.cn/v1
# OPENAI_MODEL=moonshot-v1-8k

# === 通义千问 ===
# OPENAI_API_KEY=sk-your-qwen-key
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_MODEL=qwen-turbo

# ============================================
# Agent 配置
# ============================================

# Agent 标识（唯一）
AGENT_ID=coder-agent-1

# Agent 角色: coder, pm, reviewer
AGENT_ROLE=coder

# Agent 显示名称
AGENT_NAME=程序员

# 工作目录
WORKSPACE=/workspace

# 轮询间隔（秒）
POLL_INTERVAL=30

# ============================================
# 多 Agent 配置示例
# ============================================

# PM Agent (使用更强的模型)
# AGENT_ID=pm-agent-1
# AGENT_ROLE=pm
# AGENT_NAME=项目经理
# OPENAI_MODEL=glm-4-plus

# Coder Agent (使用快速模型)
# AGENT_ID=coder-agent-1
# AGENT_ROLE=coder
# AGENT_NAME=程序员
# OPENAI_MODEL=glm-4-flash

# Reviewer Agent (使用更强的模型)
# AGENT_ID=reviewer-agent-1
# AGENT_ROLE=reviewer
# AGENT_NAME=代码审查员
# OPENAI_MODEL=glm-4-plus
